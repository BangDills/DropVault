# Apache rewrite for pretty URLs. Place in the dir containing index.php.
# Allows: /login, /s/abc123, /api/files, etc.
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Serve real files/dirs directly (assets, etc).
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route everything else to index.php; PATH_INFO carries the route.
    RewriteRule ^(.*)$ index.php/$1 [QSA,L]
</IfModule>

# Hide dotfiles.
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# PHP upload limits (cPanel may override; also set in cPanel MultiPHP INI).
<IfModule mod_php.c>
    php_value upload_max_filesize 512M
    php_value post_max_size 512M
    php_value max_execution_time 300
</IfModule>
